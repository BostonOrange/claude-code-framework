# App
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Local-first auth. Use AUTH_MODE=oidc in hosted environments.
AUTH_MODE=dev
SESSION_SECRET=replace-by-running-npm-run-setup

# Microsoft Entra ID or another OIDC provider. Required when AUTH_MODE=oidc.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ALLOWED_EMAIL_DOMAINS=

# Local Postgres from docker-compose.yml
DATABASE_URL=postgresql://app:app@localhost:55432/app_creator?schema=public
# Hosted Postgres: Vercel Marketplace, Neon, Supabase, and Azure Postgres all flow through DATABASE_URL.

# Local blob storage from Azurite. Replace with an Azure Storage connection string in prod.
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_CONTAINER=app-files
# Vercel Blob adapter env. Keep application code behind src/lib/blob/client.ts.
BLOB_READ_WRITE_TOKEN=

# AI. The default mock provider lets the app run without external credentials.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
